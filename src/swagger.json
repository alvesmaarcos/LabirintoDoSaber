{
  "openapi": "3.0.0",
  "info": {
    "title": "Maze of Knowledge API",
    "description": "RESTful API documentation for the 'Maze of Knowledge' project.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000/",
      "description": "Local Development Server"
    },
    {
      "url": "https://labirinto-do-saber.vercel.app",
      "description": "Production Server"
    }
  ],
  "paths": {
    "/educator/register": {
      "post": {
        "tags": ["Educator - Auth"],
        "summary": "Creates a new Educator account.",
        "requestBody": {
          "description": "Educator data for registration.",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EducatorRegisterBody" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Educator registered successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Educator" }
              }
            }
          },
          "400": { "description": "Email already in use or invalid data." }
        }
      }
    },
    "/educator/sign-in": {
      "post": {
        "tags": ["Educator - Auth"],
        "summary": "Authenticates an Educator and returns the JWT token.",
        "requestBody": {
          "description": "Educator credentials.",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EducatorSignInBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthSuccessResponse" }
              }
            }
          },
          "401": { "description": "Invalid credentials." }
        }
      }
    },
    "/educator/update-password": {
      "post": {
        "tags": ["Educator - Profile"],
        "summary": "Updates the educator's password.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "description": "Email and new password. (Authorization is assumed via token.)",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EducatorUpdatePasswordBody" }
            }
          }
        },
        "responses": {
          "200": { "description": "Password updated successfully." },
          "401": { "description": "Unauthorized or incorrect credentials." }
        }
      }
    },
    "/educator/generate-token": {
      "put": {
        "tags": ["Educator - Auth"],
        "summary": "Generates a password recovery token and sends it via email.",
        "requestBody": {
          "description": "Educator email for token delivery.",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GenerateAuthTokenBody" }
            }
          }
        },
        "responses": {
          "200": { "description": "Token generated and sent (or success to prevent email leakage)." },
          "404": { "description": "Email not found." }
        }
      }
    },
    "/student/create": {
      "post": {
        "tags": ["Student - Management (Educator Only)"],
        "summary": "Creates a new Student record.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "description": "Data for the new student.",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/StudentCreationBody" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Student created successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Student" }
              }
            }
          },
          "401": { "description": "Unauthorized. Missing or invalid token." }
        }
      }
    },
    "/student/assign-educator": {
      "post": {
        "tags": ["Student - Management (Educator Only)"],
        "summary": "Assigns an existing student to a new educator.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "description": "Student ID and new Educator's email.",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AssignEducatorBody" }
            }
          }
        },
        "responses": {
          "200": { "description": "Educator assigned successfully." },
          "401": { "description": "Unauthorized." },
          "404": { "description": "Student or Educator not found." }
        }
      }
    },
    "/student/": {
      "get": {
        "tags": ["Student - Management (Educator Only)"],
        "summary": "Lists all students assigned to the authenticated Educator.",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of students returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Student" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized." }
        }
      }
    },
    "/task-notebook/create": {
      "post": {
        "tags": ["Task Notebook (Educator Only)"],
        "summary": "Creates a new Task Notebook (a group of existing tasks).",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "description": "List of task IDs, category, and description for the new notebook.",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TaskNotebookCreationBody" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Notebook created successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TaskNotebook" }
              }
            }
          },
          "401": { "description": "Unauthorized." }
        }
      }
    },
    "/task-notebook/": {
      "get": {
        "tags": ["Task Notebook (Educator Only)"],
        "summary": "Lists and filters task notebooks created by the educator.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "query", "schema": { "type": "string", "format": "uuid" }, "required": false, "description": "Filter by specific Task Notebook ID." },
          { "name": "educatorId", "in": "query", "schema": { "type": "string", "format": "uuid" }, "required": false, "description": "Filter by Educator ID (only useful for administrators or if educator can view others)." },
          { "name": "category", "in": "query", "schema": { "type": "string" }, "required": false, "description": "Filter by notebook category." },
          { "name": "descriptionContains", "in": "query", "schema": { "type": "string" }, "required": false, "description": "Filter by text contained in the description." }
        ],
        "responses": {
          "200": {
            "description": "List of task notebooks returned successfully.",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TaskNotebook" } }
              }
            }
          },
          "401": { "description": "Unauthorized." }
        }
      }
    },
    "/task/create": {
      "post": {
        "tags": ["Task Management (Educator Only)"],
        "summary": "Creates a new Task (quiz question).",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "description": "Task content, alternatives, category, and type.",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TaskCreationBody" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Task created successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Task" }
              }
            }
          },
          "401": { "description": "Unauthorized." }
        }
      }
    },
    "/task/": {
      "get": {
        "tags": ["Task Management (Educator Only)"],
        "summary": "Lists and filters tasks created by the educator.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "query", "schema": { "type": "string", "format": "uuid" }, "required": false, "description": "Filter by specific Task ID." },
          { "name": "category", "in": "query", "schema": { "type": "string" }, "required": false, "description": "Filter by category." },
          { "name": "type", "in": "query", "schema": { "type": "string" }, "required": false, "description": "Filter by task type." },
          { "name": "promptContains", "in": "query", "schema": { "type": "string" }, "required": false, "description": "Filter by text contained in the prompt." }
        ],
        "responses": {
          "200": {
            "description": "List of tasks returned successfully.",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Task" } }
              }
            }
          },
          "401": { "description": "Unauthorized." }
        }
      }
    },
    "/task/update": {
      "put": {
        "tags": ["Task Management (Educator Only)"],
        "summary": "Updates an existing Task.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "description": "Task ID and optional fields to update.",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TaskUpdateBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task updated successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Task" }
              }
            }
          },
          "401": { "description": "Unauthorized." },
          "404": { "description": "Task not found." }
        }
      }
    },
    "/task/delete/{id}": { 
      "delete": {
        "tags": ["Task Management (Educator Only)"],
        "summary": "Deletes a Task by its ID.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": { "type": "string", "format": "uuid" },
            "required": true,
            "description": "The ID of the Task to be deleted."
          }
        ],
        "responses": {
          "204": { "description": "Task successfully deleted (No Content)." },
          "401": { "description": "Unauthorized. Missing or invalid token." },
          "404": { "description": "Task not found." }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Educator": {
        "type": "object",
        "description": "Educator data model.",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        },
        "required": ["id", "name", "email"]
      },
      "Student": {
        "type": "object",
        "description": "Student data model.",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email", "nullable": true },
          "age": { "type": "integer" },
          "gender": { "type": "string" },
          "zipcode": { "type": "string" },
          "road": { "type": "string" },
          "housenumber": { "type": "string" },
          "phonenumber": { "type": "string" },
          "learningTopics": { "type": "array", "items": { "type": "string" } },
          "educatorId": { "type": "string", "format": "uuid", "nullable": true, "description": "ID of the assigned educator." }
        }
      },
      "TaskAlternative": {
        "type": "object",
        "properties": {
          "text": { "type": "string", "minLength": 1, "description": "The text content of the alternative." },
          "isCorrect": { "type": "boolean", "description": "Flag indicating if this alternative is the correct answer." }
        },
        "required": ["text", "isCorrect"]
      },
      "Task": {
        "type": "object",
        "description": "Model for a single quiz/assessment task.",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "category": { "type": "string", "description": "The category of the task (e.g., Mathematics, History)." },
          "type": { "type": "string", "description": "The type of task (e.g., MultipleChoice, TrueOrFalse)." },
          "prompt": { "type": "string", "description": "The question or statement for the task." },
          "alternatives": { "type": "array", "items": { "$ref": "#/components/schemas/TaskAlternative" }, "minItems": 2 },
          "imageFile": { "type": "string", "nullable": true, "description": "URL or path to an associated image file." },
          "audioFile": { "type": "string", "nullable": true, "description": "URL or path to an associated audio file." }
        }
      },
      "TaskNotebook": {
        "type": "object",
        "description": "Model for a Task Notebook (a collection of tasks).",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "educatorId": { "type": "string", "format": "uuid" },
          "category": { "type": "string" },
          "description": { "type": "string" },
          "tasks": { "type": "array", "items": { "type": "string", "format": "uuid" }, "description": "List of Task IDs." }
        }
      },
      "AuthSuccessResponse": {
        "type": "object",
        "description": "Standard success response after login.",
        "properties": {
          "token": { "type": "string", "description": "JWT access token." },
          "educator": { "$ref": "#/components/schemas/Educator" }
        },
        "required": ["token", "educator"]
      },
      "EducatorRegisterBody": {
        "type": "object",
        "description": "Required data for new Educator registration.",
        "properties": {
          "name": { "type": "string", "description": "Educator's full name.", "minLength": 3, "maxLength": 100 },
          "email": { "type": "string", "format": "email", "description": "Valid email for access." },
          "password": { "type": "string", "description": "Account password.", "minLength": 6, "maxLength": 100 }
        },
        "required": ["name", "email", "password"]
      },
      "EducatorSignInBody": {
        "type": "object",
        "description": "Credentials for Educator login.",
        "properties": {
          "email": { "type": "string", "format": "email", "description": "Educator's email." },
          "password": { "type": "string", "description": "Educator's password.", "minLength": 6, "maxLength": 100 }
        },
        "required": ["email", "password"]
      },
      "EducatorUpdatePasswordBody": {
        "type": "object",
        "description": "Data for password update.",
        "properties": {
          "email": { "type": "string", "format": "email", "description": "Educator's email." },
          "newPassword": { "type": "string", "description": "New desired password.", "minLength": 6, "maxLength": 100 }
        },
        "required": ["email", "newPassword"]
      },
      "GenerateAuthTokenBody": {
        "type": "object",
        "description": "Email to which the recovery/authentication token should be sent.",
        "properties": {
          "educatorEmail": { "type": "string", "format": "email", "description": "Educator's email." }
        },
        "required": ["educatorEmail"]
      },
      "StudentCreationBody": {
        "type": "object",
        "description": "Required body for creating a new Student.",
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 100 },
          "age": { "type": "integer", "minimum": 1, "maximum": 50 },
          "gender": { "type": "string", "description": "Student's gender (e.g., Male, Female, Other)." },
          "zipcode": { "type": "string", "minLength": 5, "maxLength": 10 },
          "road": { "type": "string", "minLength": 1, "maxLength": 100 },
          "housenumber": { "type": "string", "minLength": 1, "maxLength": 10 },
          "phonenumber": { "type": "string", "minLength": 7, "maxLength": 15 },
          "learningTopics": { 
            "type": "array", 
            "items": { "type": "string", "minLength": 1, "maxLength": 50 },
            "minItems": 1
          }
        },
        "required": ["name", "age", "gender", "zipcode", "road", "housenumber", "phonenumber", "learningTopics"]
      },
      "AssignEducatorBody": {
        "type": "object",
        "description": "Body to assign a student to a new educator.",
        "properties": {
          "studentId": { "type": "string", "format": "uuid", "description": "The ID of the student to be assigned." },
          "newEducatorEmail": { "type": "string", "format": "email", "description": "Email of the new educator to be assigned." }
        },
        "required": ["studentId", "newEducatorEmail"]
      },
      "TaskNotebookCreationBody": {
        "type": "object",
        "properties": {
          "tasks": {
            "type": "array",
            "items": { "type": "string", "format": "uuid" },
            "minItems": 1,
            "description": "List of Task IDs to be included in the notebook."
          },
          "category": { "type": "string" },
          "description": { "type": "string", "minLength": 1 }
        },
        "required": ["tasks", "category", "description"]
      },
      "TaskCreationBody": {
        "type": "object",
        "properties": {
          "category": { "type": "string" },
          "type": { "type": "string" },
          "prompt": { "type": "string", "minLength": 1 },
          "alternatives": { "type": "array", "items": { "$ref": "#/components/schemas/TaskAlternative" }, "minItems": 2 },
          "imageFile": { "type": "string", "nullable": true, "description": "Optional image file path." },
          "audioFile": { "type": "string", "nullable": true, "description": "Optional audio file path." }
        },
        "required": ["category", "type", "prompt", "alternatives"]
      },
      "TaskUpdateBody": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "category": { "type": "string", "nullable": true },
          "type": { "type": "string", "nullable": true },
          "prompt": { "type": "string", "minLength": 1, "nullable": true },
          "alternatives": { "type": "array", "items": { "$ref": "#/components/schemas/TaskAlternative" }, "nullable": true },
          "imageFile": { "type": "string", "nullable": true },
          "audioFile": { "type": "string", "nullable": true }
        },
        "required": ["id"]
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}