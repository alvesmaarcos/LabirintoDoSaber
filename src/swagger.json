{
  "openapi": "3.0.0",
  "info": {
    "title": "Maze of Knowledge API",
    "description": "RESTful API documentation for the 'Maze of Knowledge' project.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000/",
      "description": "Local Development Server"
    },
    {
      "url": "https://labirinto-do-saber.vercel.app",
      "description": "Production Server"
    }
  ],
  "paths": {
    "/educator/register": {
      "post": {
        "tags": ["Educator - Auth"],
        "summary": "Creates a new Educator account.",
        "requestBody": {
          "description": "Educator data for registration.",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EducatorRegisterBody" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Educator registered successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Educator" }
              }
            }
          },
          "400": { "description": "Email already in use or invalid data." }
        }
      }
    },
    "/educator/sign-in": {
      "post": {
        "tags": ["Educator - Auth"],
        "summary": "Authenticates an Educator and returns the JWT token.",
        "requestBody": {
          "description": "Educator credentials.",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EducatorSignInBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthSuccessResponse" }
              }
            }
          },
          "401": { "description": "Invalid credentials." }
        }
      }
    },
    "/educator/update-password": {
      "post": {
        "tags": ["Educator - Profile"],
        "summary": "Updates the educator's password.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "description": "Email and new password. (Authorization is assumed via token.)",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EducatorUpdatePasswordBody"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password updated successfully." },
          "401": { "description": "Unauthorized or incorrect credentials." }
        }
      }
    },
    "/educator/generate-token": {
      "put": {
        "tags": ["Educator - Auth"],
        "summary": "Generates a password recovery token and sends it via email.",
        "requestBody": {
          "description": "Educator email for token delivery.",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GenerateAuthTokenBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token generated and sent (or success to prevent email leakage)."
          },
          "404": { "description": "Email not found." }
        }
      }
    },
    "/student/create": {
      "post": {
        "tags": ["Student - Management (Educator Only)"],
        "summary": "Creates a new Student record.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "description": "Data for the new student.",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/StudentCreationBody" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Student created successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Student" }
              }
            }
          },
          "401": { "description": "Unauthorized. Missing or invalid token." }
        }
      }
    },
    "/student/assign-educator": {
      "post": {
        "tags": ["Student - Management (Educator Only)"],
        "summary": "Assigns an existing student to a new educator.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "description": "Student ID and new Educator's email.",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AssignEducatorBody" }
            }
          }
        },
        "responses": {
          "200": { "description": "Educator assigned successfully." },
          "401": { "description": "Unauthorized." },
          "404": { "description": "Student or Educator not found." }
        }
      }
    },
    "/student/": {
      "get": {
        "tags": ["Student - Management (Educator Only)"],
        "summary": "Lists all students assigned to the authenticated Educator.",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of students returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Student" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized." }
        }
      }
    },
    "/task-notebook/create": {
      "post": {
        "tags": ["Task Notebook (Educator Only)"],
        "summary": "Creates a new Task Notebook (a group of existing tasks).",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "description": "List of task IDs, category, and description for the new notebook.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskNotebookCreationBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Notebook created successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TaskNotebook" }
              }
            }
          },
          "401": { "description": "Unauthorized." }
        }
      }
    },
    "/task-notebook/": {
      "get": {
        "tags": ["Task Notebook (Educator Only)"],
        "summary": "Lists and filters task notebooks created by the educator.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "schema": { "type": "string", "format": "uuid" },
            "required": false,
            "description": "Filter by specific Task Notebook ID."
          },
          {
            "name": "educatorId",
            "in": "query",
            "schema": { "type": "string", "format": "uuid" },
            "required": false,
            "description": "Filter by Educator ID (only useful for administrators or if educator can view others)."
          },
          {
            "name": "category",
            "in": "query",
            "schema": { "type": "string" },
            "required": false,
            "description": "Filter by notebook category."
          },
          {
            "name": "descriptionContains",
            "in": "query",
            "schema": { "type": "string" },
            "required": false,
            "description": "Filter by text contained in the description."
          }
        ],
        "responses": {
          "200": {
            "description": "List of task notebooks returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/TaskNotebook" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized." }
        }
      }
    },
    "/task-notebook-session/start": {
      "post": {
        "tags": ["Task Notebook Session (Educator Only)"],
        "summary": "Starts a new Task Notebook session for a specific student.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "description": "Student ID and Task Notebook ID.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartTaskNotebookSessionBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session started successfully, returns the session object.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TaskNotebookSession" }
              }
            }
          },
          "400": { "description": "Invalid data format or missing fields." },
          "401": { "description": "Unauthorized. Missing or invalid token." },
          "404": { "description": "STUDENT_NOT_FOUND or NOTEBOOK_NOT_FOUND." },
          "500": {
            "description": "SESSION_CREATION_FAILED or Internal Server Error."
          }
        }
      }
    },
    "/task-notebook-session/answer": {
      "post": {
        "tags": ["Task Notebook Session (Student/Educator)"],
        "summary": "Records a student's answer for a task within an active session.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "description": "Session ID, Task ID, selected alternative ID, and time taken to answer.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnswerTaskNotebookSessionBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Answer recorded successfully. Returns the updated session object.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TaskNotebookSession" }
              }
            }
          },
          "400": {
            "description": "Invalid data format or business rules violated (SESSION_ALREADY_FINISHED, TASK_NOT_IN_NOTEBOOK, TASK_ALREADY_ANSWERED)."
          },
          "401": { "description": "Unauthorized. Missing or invalid token." },
          "404": {
            "description": "SESSION_NOT_FOUND, TASK_NOT_FOUND, or NOTEBOOK_NOT_FOUND."
          },
          "500": {
            "description": "Internal Server Error or ANSWER_CREATION_FAILED."
          }
        }
      }
    },
    "/task-notebook-session/finish": {
      "post": {
        "tags": ["Task Notebook Session (Student/Educator)"],
        "summary": "Explicitly finishes an active Task Notebook session.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "description": "The ID of the session to be finished.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FinishTaskNotebookSessionBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session finished successfully. Returns the finalized session object with results.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TaskNotebookSession" }
              }
            }
          },
          "400": {
            "description": "Invalid data format or business rule violated (SESSION_ALREADY_FINISHED)."
          },
          "401": { "description": "Unauthorized. Missing or invalid token." },
          "404": { "description": "SESSION_NOT_FOUND." },
          "500": {
            "description": "SESSION_FINISH_FAILED or Internal Server Error."
          }
        }
      }
    },
    "/task-notebook-session/student/{studentId}": {
      "get": {
        "tags": ["Task Notebook Session (Student/Educator)"],
        "summary": "Lists all Task Notebook sessions associated with a specific student.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "studentId",
            "in": "path",
            "schema": { "type": "string", "format": "uuid" },
            "required": true,
            "description": "The ID of the student whose sessions are being requested."
          }
        ],
        "responses": {
          "200": {
            "description": "List of task notebook sessions returned successfully. Returns an empty array if none are found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TaskNotebookSession"
                  }
                }
              }
            }
          },
          "400": { "description": "Invalid studentId format." },
          "401": { "description": "Unauthorized. Missing or invalid token." }
        }
      }
    },
    "/task-notebook-session/report/{sessionId}": {
      "get": {
        "tags": ["Task Notebook Session (Student/Educator)"],
        "summary": "Generates a comprehensive performance report for a completed session.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "schema": { "type": "string", "format": "uuid" },
            "required": true,
            "description": "The ID of the Task Notebook session for which the report is requested."
          }
        ],
        "responses": {
          "200": {
            "description": "Report generated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskNotebookSessionReport"
                }
              }
            }
          },
          "400": {
            "description": "Invalid sessionId format or SESSION_NOT_FINISHED."
          },
          "401": { "description": "Unauthorized. Missing or invalid token." },
          "404": { "description": "SESSION_NOT_FOUND." },
          "500": { "description": "Internal Server Error." }
        }
      }
    },
    "/task/create": {
      "post": {
        "tags": ["Task Management (Educator Only)"],
        "summary": "Creates a new Task (quiz question).",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "description": "Task content, alternatives, category, and type.",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TaskCreationBody" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Task created successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Task" }
              }
            }
          },
          "401": { "description": "Unauthorized." }
        }
      }
    },
    "/task/": {
      "get": {
        "tags": ["Task Management (Educator Only)"],
        "summary": "Lists and filters tasks created by the educator.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "schema": { "type": "string", "format": "uuid" },
            "required": false,
            "description": "Filter by specific Task ID."
          },
          {
            "name": "category",
            "in": "query",
            "schema": { "type": "string" },
            "required": false,
            "description": "Filter by category."
          },
          {
            "name": "type",
            "in": "query",
            "schema": { "type": "string" },
            "required": false,
            "description": "Filter by task type."
          },
          {
            "name": "promptContains",
            "in": "query",
            "schema": { "type": "string" },
            "required": false,
            "description": "Filter by text contained in the prompt."
          }
        ],
        "responses": {
          "200": {
            "description": "List of tasks returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Task" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized." }
        }
      }
    },
    "/task/update": {
      "put": {
        "tags": ["Task Management (Educator Only)"],
        "summary": "Updates an existing Task.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "description": "Task ID and optional fields to update.",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TaskUpdateBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task updated successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Task" }
              }
            }
          },
          "401": { "description": "Unauthorized." },
          "404": { "description": "Task not found." }
        }
      }
    },
    "/task/delete/{id}": {
      "delete": {
        "tags": ["Task Management (Educator Only)"],
        "summary": "Deletes a Task by its ID.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": { "type": "string", "format": "uuid" },
            "required": true,
            "description": "The ID of the Task to be deleted."
          }
        ],
        "responses": {
          "204": { "description": "Task successfully deleted (No Content)." },
          "401": { "description": "Unauthorized. Missing or invalid token." },
          "404": { "description": "Task not found." }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Educator": {
        "type": "object",
        "description": "Educator data model.",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        },
        "required": ["id", "name", "email"]
      },
      "Student": {
        "type": "object",
        "description": "Student data model.",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email", "nullable": true },
          "age": { "type": "integer" },
          "gender": { "type": "string" },
          "zipcode": { "type": "string" },
          "road": { "type": "string" },
          "housenumber": { "type": "string" },
          "phonenumber": { "type": "string" },
          "learningTopics": { "type": "array", "items": { "type": "string" } },
          "educatorId": {
            "type": "string",
            "format": "uuid",
            "nullable": true,
            "description": "ID of the assigned educator."
          }
        }
      },
      "TaskAlternative": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "description": "The text content of the alternative."
          },
          "isCorrect": {
            "type": "boolean",
            "description": "Flag indicating if this alternative is the correct answer."
          }
        },
        "required": ["text", "isCorrect"]
      },
      "TaskAnswer": {
        "type": "object",
        "description": "Represents a student's recorded answer for a single task.",
        "properties": {
          "taskId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the answered task."
          },
          "selectedAlternativeId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the alternative selected by the student."
          },
          "isCorrect": {
            "type": "boolean",
            "description": "Indicates if the selected alternative was correct."
          },
          "timeToAnswer": {
            "type": "number",
            "format": "float",
            "description": "Time spent answering the task, in seconds."
          },
          "answeredAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of the answer submission."
          }
        },
        "required": [
          "taskId",
          "selectedAlternativeId",
          "isCorrect",
          "timeToAnswer",
          "answeredAt"
        ]
      },
      "Task": {
        "type": "object",
        "description": "Model for a single quiz/assessment task.",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "category": {
            "type": "string",
            "description": "The category of the task (e.g., Mathematics, History)."
          },
          "type": {
            "type": "string",
            "description": "The type of task (e.g., MultipleChoice, TrueOrFalse)."
          },
          "prompt": {
            "type": "string",
            "description": "The question or statement for the task."
          },
          "alternatives": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TaskAlternative" },
            "minItems": 2
          },
          "imageFile": {
            "type": "string",
            "nullable": true,
            "description": "URL or path to an associated image file."
          },
          "audioFile": {
            "type": "string",
            "nullable": true,
            "description": "URL or path to an associated audio file."
          }
        }
      },
      "TaskNotebook": {
        "type": "object",
        "description": "Model for a Task Notebook (a collection of tasks).",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "educatorId": { "type": "string", "format": "uuid" },
          "category": { "type": "string" },
          "description": { "type": "string" },
          "tasks": {
            "type": "array",
            "items": { "type": "string", "format": "uuid" },
            "description": "List of Task IDs."
          }
        }
      },
      "TaskNotebookSession": {
        "type": "object",
        "description": "The active Task Notebook session model.",
        "properties": {
          "sessionId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique ID for the session."
          },
          "studentId": { "type": "string", "format": "uuid" },
          "notebookId": { "type": "string", "format": "uuid" },
          "startedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the session started."
          },
          "finishedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "Timestamp when the session finished, null if still active."
          },
          "status": {
            "type": "string",
            "enum": ["IN_PROGRESS", "COMPLETED", "EXPIRED"],
            "description": "Current status of the session."
          },
          "answers": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TaskAnswer" },
            "description": "List of recorded answers for the tasks in the notebook."
          }
        },
        "required": [
          "sessionId",
          "studentId",
          "notebookId",
          "startedAt",
          "status",
          "answers"
        ]
      },
      "TaskNotebookSessionReport": {
        "type": "object",
        "description": "Comprehensive performance metrics for a Task Notebook Session.",
        "properties": {
          "totalTimeSession": {
            "type": "number",
            "format": "float",
            "description": "Total time spent in the session, in seconds."
          },
          "totalQuestions": {
            "type": "integer",
            "description": "Total number of questions answered."
          },
          "averageTimePerQuestion": {
            "type": "number",
            "format": "float",
            "description": "Average time spent per question (seconds)."
          },
          "averageCorrectTime": {
            "type": "number",
            "format": "float",
            "nullable": true,
            "description": "Average time spent on correct answers (seconds). Null if no correct answers."
          },
          "averageIncorrectTime": {
            "type": "number",
            "format": "float",
            "nullable": true,
            "description": "Average time spent on incorrect answers (seconds). Null if no incorrect answers."
          },
          "percentageByCategory": {
            "type": "object",
            "additionalProperties": {
              "type": "number",
              "format": "float",
              "nullable": true,
              "description": "Percentage of correct answers for a given category (0-100)."
            },
            "description": "Performance percentage grouped by question category."
          },
          "percentageByType": {
            "type": "object",
            "additionalProperties": {
              "type": "number",
              "format": "float",
              "nullable": true,
              "description": "Percentage of correct answers for a given question type (0-100)."
            },
            "description": "Performance percentage grouped by question type."
          }
        },
        "required": [
          "totalTimeSession",
          "totalQuestions",
          "averageTimePerQuestion",
          "percentageByCategory",
          "percentageByType"
        ]
      },
      "AuthSuccessResponse": {
        "type": "object",
        "description": "Standard success response after login.",
        "properties": {
          "token": { "type": "string", "description": "JWT access token." },
          "educator": { "$ref": "#/components/schemas/Educator" }
        },
        "required": ["token", "educator"]
      },
      "EducatorRegisterBody": {
        "type": "object",
        "description": "Required data for new Educator registration.",
        "properties": {
          "name": {
            "type": "string",
            "description": "Educator's full name.",
            "minLength": 3,
            "maxLength": 100
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Valid email for access."
          },
          "password": {
            "type": "string",
            "description": "Account password.",
            "minLength": 6,
            "maxLength": 100
          }
        },
        "required": ["name", "email", "password"]
      },
      "EducatorSignInBody": {
        "type": "object",
        "description": "Credentials for Educator login.",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Educator's email."
          },
          "password": {
            "type": "string",
            "description": "Educator's password.",
            "minLength": 6,
            "maxLength": 100
          }
        },
        "required": ["email", "password"]
      },
